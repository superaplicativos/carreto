# Supabase — Connection URLs (pegue no painel: Connect → ORMs → Prisma)

# Pooler transacional (IPv4, porta 6543) — usado pela aplicação em runtime (serverless-friendly)
DATABASE_URL="postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# Pooler session-mode (porta 5432) — usado para migrations/Prisma db push
DIRECT_URL="postgresql://postgres.SEU_PROJECT_REF:SUA_SENHA@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# Supabase Realtime (pegue em: Project Settings → API)
# URL do projeto (visível/publicável — pode ir no frontend)
NEXT_PUBLIC_SUPABASE_URL="https://SEU_PROJECT_REF.supabase.co"

# Chave "anon public" (NÃO é a service_role — essa é pública por design)
# Permite que o browser se conecte ao Realtime. RLS protege os dados.
NEXT_PUBLIC_SUPABASE_ANON_KEY="eyJhbGciOiJIUzI1NiIsInR5cCI6..."

# Notas:
# - Substitua SEU_PROJECT_REF pelo ref do seu projeto (encontrado na URL do painel)
# - Substitua SUA_SENHA pela senha definida na criação do projeto
# - Caracteres especiais na senha (como #) devem ser URL-encoded (%23 para #)
# - As 4 variáveis devem ser configuradas no Vercel em Settings → Environment Variables
